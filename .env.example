# Postgres connection. Use `?sslmode=disable` for local dev only.
LUMI_DATABASE_URL=postgres://lumi:lumi@localhost:5432/lumi?sslmode=disable

# Filesystem root: vaults live as <LUMI_ROOT>/<vault-slug>/
LUMI_ROOT=./vaults

# HTTP listen port
LUMI_PORT=8080

# Refuse non-TLS listeners except on 127.0.0.1 when true
LUMI_REQUIRE_TLS=false

# Comma-separated origin allowlist for CORS and WS upgrade
LUMI_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Registration policy: invite-only (default) or open
LUMI_REGISTRATION=invite-only

# LGPD audit retention in days (default 90)
LUMI_AUDIT_RETENTION_DAYS=90

# Optional initial-admin bootstrap (used on first run when DB is empty)
LUMI_ADMIN_USERNAME=
LUMI_ADMIN_PASSWORD=

# ToS / Privacy URLs surfaced via /api/legal/*
LUMI_TOS_URL=
LUMI_PRIVACY_URL=
LUMI_TOS_VERSION=2026-04-28
LUMI_PRIVACY_VERSION=2026-04-28
